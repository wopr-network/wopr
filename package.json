{
  "name": "@wopr-network/wopr",
  "version": "2.0.2",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "bin": {
    "wopr": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.ts",
    "daemon": "tsx src/daemon/index.ts",
    "daemon:start": "tsx src/cli.ts daemon start",
    "daemon:stop": "tsx src/cli.ts daemon stop",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "format": "biome format --write src/",
    "check": "biome check src/ && tsc --noEmit",
    "generate:openapi": "tsx scripts/generate-openapi.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:compose": "tsx scripts/generate-compose.ts"
  },
  "overrides": {
    "tar": "^7.5.7",
    "@isaacs/brace-expansion": "^5.0.1"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@clack/prompts": "^1.1.0",
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.0",
    "@hono/standard-validator": "^0.2.2",
    "@scalar/hono-api-reference": "^0.10.3",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.7",
    "hono-openapi": "^1.3.0",
    "hono-rate-limiter": "^0.5.3",
    "hyperswarm": "^4.17.0",
    "picocolors": "^1.1.1",
    "sqlite-vec": "0.1.7-alpha.2",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "overrides": {
      "rollup": "^4.59.0"
    }
  }
}
