# WOPR Environment Variables
# Copy this file to .env and fill in your values

# ---------------------------------------------------------------------------
# Paths & Directories
# ---------------------------------------------------------------------------

# Root directory for WOPR data (plugins, config, state).
# Default: ${HOME}/wopr
# WOPR_HOME=${HOME}/wopr

# Active workspace directory (where agents work).
# Default: auto-resolved under WOPR_HOME
# WOPR_WORKSPACE=${WOPR_HOME}/workspace

# Directory for the global agent identity keypair.
# Default: ${WOPR_HOME}/identity
# WOPR_GLOBAL_IDENTITY=${WOPR_HOME}/identity

# ---------------------------------------------------------------------------
# Daemon
# ---------------------------------------------------------------------------

# Port the WOPR daemon listens on.
# Default: 7437
# WOPR_DAEMON_PORT=7437

# Host the WOPR daemon binds to.
# Default: 127.0.0.1
# WOPR_DAEMON_HOST=127.0.0.1

# ---------------------------------------------------------------------------
# Authentication & API Keys
# ---------------------------------------------------------------------------

# Note: WOPR uses Claude Code OAuth credentials from ~/.claude/.credentials.json
# No API key needed if you're logged into Claude Code.

# Anthropic API key (optional – overrides OAuth credentials when set).
# Get from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# WOPR platform API key (for hosted capability access).
# WOPR_API_KEY=

# WOPR platform base URL (override for self-hosted deployments).
# Default: https://api.wopr.network
# WOPR_API_BASE_URL=https://api.wopr.network

# WOPR platform token (used for hosted capabilities such as TTS, ImageGen).
# WOPR_PLATFORM_TOKEN=

# AES-256 key for encrypting stored credentials (hex string, 64 chars).
# Generate with: openssl rand -hex 32
# WOPR_CREDENTIAL_KEY=

# ---------------------------------------------------------------------------
# Claude OAuth (alternative to API key – set all three or none)
# ---------------------------------------------------------------------------

# OAuth token URL (override to use a custom OAuth provider endpoint).
# Default: https://console.anthropic.com/v1/oauth/token
# WOPR_OAUTH_TOKEN_URL=https://console.anthropic.com/v1/oauth/token

# Claude OAuth access token (set via `wopr auth login` or manually).
# WOPR_CLAUDE_OAUTH_TOKEN=

# Claude OAuth refresh token.
# WOPR_CLAUDE_REFRESH_TOKEN=

# Claude OAuth token expiry (Unix timestamp in milliseconds).
# WOPR_CLAUDE_OAUTH_EXPIRES_AT=

# ---------------------------------------------------------------------------
# Plugin Configuration
# ---------------------------------------------------------------------------

# JSON-encoded plugin config override (advanced – use config file instead).
# WOPR_PLUGIN_CONFIG={}

# Security enforcement level: "strict" | "warn" | "off"
# Defaults to "strict" in production, "warn" otherwise.
# WOPR_SECURITY_ENFORCEMENT=warn

# ---------------------------------------------------------------------------
# LLM Provider API Keys (optional – enable additional embedding providers)
# ---------------------------------------------------------------------------

# OpenAI API key (enables OpenAI embeddings during onboarding).
# OPENAI_API_KEY=sk-...

# Google / Gemini API key (enables Google embeddings during onboarding).
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# Ollama base URL (enables local Ollama embeddings).
# Default: http://localhost:11434
# OLLAMA_HOST=http://localhost:11434

# ---------------------------------------------------------------------------
# Discord Integration (optional)
# ---------------------------------------------------------------------------

# Discord bot token.
# Get from: https://discord.com/developers/applications
# DISCORD_TOKEN=

# Discord guild (server) ID to restrict bot commands to.
# DISCORD_GUILD_ID=

# ---------------------------------------------------------------------------
# Logging & Development
# ---------------------------------------------------------------------------

# Log level: "error" | "warn" | "info" | "debug" | "trace"
# Default: info
# LOG_LEVEL=info

# Enable verbose debug output for specific modules (e.g. "wopr:plugins").
# DEBUG=

# Runtime environment: "development" | "production" | "test"
# Default: development
# NODE_ENV=development
